{
  "name": "daryll-and-admin1-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/generate-env.js && cd build && npm ci --omit=dev && pm2 --no-daemon start ../ecosystem.config.cjs",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.1.0",
    "@adonisjs/prettier-config": "^1.5.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/d3": "^7.4.3",
    "@types/file-saver": "^2.0.7",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/core": "^7.3.3",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/inertia": "^4.2.0",
    "@adonisjs/limiter": "^3.0.1",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/session": "^8.1.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^5.1.1",
    "@inertiajs/react": "^3.3.0",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.17.0",
    "@vinejs/vine": "^4.4.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.4.0",
    "edge.js": "^6.5.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "luxon": "^3.7.2",
    "motion": "^12.40.0",
    "mysql2": "^3.22.4",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0",
    "react-select": "^5.10.2",
    "reflect-metadata": "^0.2.2",
    "short-uuid": "^6.0.3",
    "sweetalert2": "^11.26.25",
    "tailwind-merge": "^3.6.0",
    "ua-parser-js": "^2.0.10"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
